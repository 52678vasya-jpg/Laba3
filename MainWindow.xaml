<Window x:Class="InflationAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Laboratory Works"
        Height="400"
        Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid>

        <Border Background="White"
                Margin="30"
                CornerRadius="15"
                Padding="20">

            <StackPanel>

                <!-- Заголовок -->
                <TextBlock Text="Laboratory Works"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0 0 0 30"
                           HorizontalAlignment="Center"/>

                <!-- Вариант 1 -->
                <Button Content="Variant 1 - Inflation Analyzer"
                        Height="50"
                        Margin="0 0 0 15"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#4F46E5"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Variant1Button_Click"/>

                <!-- Вариант 2 -->
                <Button Content="Variant 2"
                        Height="50"
                        Margin="0 0 0 15"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#10B981"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Variant2Button_Click"/>

                <!-- Вариант 3 -->
                <Button Content="Variant 3"
                        Height="50"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#F59E0B"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Variant3Button_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>