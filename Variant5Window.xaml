<Window x:Class="PopulationApp.Variant5Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Статистика населения РФ (Вариант 5)" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <Button Content="Загрузить JSON" Click="LoadData_Click" Padding="5" Margin="0,0,0,10"/>

            <TextBlock Text="Данные (млн. чел.):" FontWeight="Bold" Margin="0,0,0,5"/>
            <DataGrid x:Name="DataGridPopulation" AutoGenerateColumns="True" Height="200" Margin="0,0,0,10"/>

            <TextBlock x:Name="TxtStats" TextWrapping="Wrap" Foreground="DarkBlue" Margin="0,0,0,10"/>

            <TextBlock Text="Настройки прогноза:" FontWeight="Bold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Период скользящей (n): " VerticalAlignment="Center"/>
                <TextBox x:Name="TxtN" Width="50" Text="3"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Прогноз (лет): " VerticalAlignment="Center"/>
                <TextBox x:Name="TxtYears" Width="50" Text="5"/>
            </StackPanel>

            <Button Content="Построить прогноз" Click="Predict_Click" Padding="5" Margin="0,0,0,10"/>
            <Button Content="Экспорт графика (PNG)" Click="Export_Click" Padding="5"/>
        </StackPanel>

        <oxy:PlotView x:Name="PlotPopulation" Grid.Column="1"/>
    </Grid>
</Window>