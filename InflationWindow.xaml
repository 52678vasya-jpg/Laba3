<Window x:Class="InflationAnalyzer.InflationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Inflation Analyzer"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="250"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0 0 0 15">

            <WrapPanel>

                <!-- Кнопка загрузки -->
                <Button x:Name="LoadButton"
                        Content="Load JSON"
                        Width="140"
                        Height="40"
                        Margin="0 0 15 0"
                        Background="#4F46E5"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Click="LoadButton_Click"/>

                <!-- Подпись -->
                <TextBlock Text="Forecast year:"
                           VerticalAlignment="Center"
                           Margin="0 0 10 0"
                           FontWeight="SemiBold"/>

                <!-- Поле ввода -->
                <TextBox x:Name="YearTextBox"
                         Width="100"
                         Height="35"
                         Text="2040"
                         Margin="0 0 15 0"/>

                <!-- Кнопка прогноза -->
                <Button x:Name="ForecastButton"
                        Content="Forecast"
                        Width="140"
                        Height="40"
                        Background="#10B981"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Click="ForecastButton_Click"/>

            </WrapPanel>
        </Border>

        <!-- Таблица -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="10"
                Margin="0 0 0 15">

            <GroupBox Header="Inflation Table">

                <DataGrid x:Name="InflationGrid"
                          AutoGenerateColumns="True"/>

            </GroupBox>
        </Border>

        <!-- График -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="10">

            <GroupBox Header="Inflation Chart">

                <oxy:PlotView x:Name="PlotView"/>

            </GroupBox>
        </Border>

    </Grid>
</Window>